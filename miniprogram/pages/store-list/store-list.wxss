.page { min-height: 100vh; background: #fbf6ee; padding: 32rpx 28rpx; }
.header { padding: 16rpx 0 32rpx; }
.title { font-size: 38rpx; font-weight: 800; color: #1f1a17; }
.sub { margin-top: 8rpx; color: #9a8e84; font-size: 24rpx; }
.empty { text-align: center; padding: 80rpx 0; color: #9a8e84; }
.store-list { display: flex; flex-direction: column; gap: 18rpx; }
.store-row {
  display: flex; align-items: center; gap: 20rpx;
  background: #fff; border-radius: 20rpx; padding: 22rpx 24rpx;
}
.store-photo { width: 120rpx; height: 120rpx; border-radius: 16rpx; overflow: hidden; flex-shrink: 0; }
.photo-img { width: 100%; height: 100%; }
.photo-placeholder {
  width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #f7d6cf 0%, #c93434 100%);
  color: #fff; font-size: 48rpx; font-weight: 700;
}
.store-meta { flex: 1; min-width: 0; }
.store-name { font-size: 30rpx; font-weight: 700; color: #1f1a17; }
.store-area { margin-top: 8rpx; color: #c93434; font-size: 24rpx; }
.store-addr {
  margin-top: 4rpx; color: #9a8e84; font-size: 22rpx;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.arrow { color: #c0b6a8; font-size: 36rpx; }
