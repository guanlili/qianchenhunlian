page {
  background: #fbf6ee;
  color: #1f1a17;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.qy-page,
.screen {
  min-height: 100vh;
  background: #fbf6ee;
}

.screen {
  height: 100vh;
  box-sizing: border-box;
}

.main-screen {
  padding-bottom: 150rpx;
}

.child-screen {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.child-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.with-bottom {
  padding-bottom: 190rpx;
}

.hero-header,
.solid-header {
  background: linear-gradient(135deg, #c93434 0%, #8f1f1f 54%, #5a0e0e 100%);
  color: #ffffff;
  position: relative;
}

.hero-header::after,
.solid-header:not(.flat)::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: radial-gradient(circle at 80% 22%, rgba(255, 213, 145, 0.28), transparent 42%),
    radial-gradient(circle at 18% 78%, rgba(255, 117, 107, 0.22), transparent 48%);
  pointer-events: none;
}

.solid-header.flat {
  background: #c93434;
  padding-bottom: 30rpx;
}

.hero-header {
  padding: 64rpx 28rpx 34rpx;
}

.hero-header.compact {
  padding-bottom: 48rpx;
}

.solid-header {
  padding: 64rpx 28rpx 26rpx;
}

.profile-header {
  padding-bottom: 52rpx;
}

.me-header {
  padding-bottom: 66rpx;
}

.nav-row {
  position: relative;
  z-index: 1;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-row .nav-link,
.nav-row .nav-title,
.nav-row .nav-placeholder {
  min-width: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-link,
.nav-placeholder {
  width: 150rpx;
  flex-shrink: 0;
  min-height: 56rpx;
  padding: 0;
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.nav-link.right {
  justify-content: flex-end;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.notice-card,
.follow-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.96);
  color: #1f1a17;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(98, 21, 21, 0.14);
}

.notice-card {
  margin-top: 22rpx;
  padding: 22rpx 18rpx;
}

.brand-seal {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: #f9e5e0;
  color: #a82626;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.05;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-family: "Songti SC", "Noto Serif SC", serif;
}

.notice-copy {
  flex: 1;
  min-width: 0;
}

.notice-copy view {
  font-size: 28rpx;
  font-weight: 700;
}

.notice-copy text,
.follow-card text {
  display: block;
  margin-top: 4rpx;
  color: #8d8175;
  font-size: 23rpx;
}

.gold-btn {
  background: linear-gradient(90deg, #f4a23a, #ed7030);
  color: #ffffff;
  border-radius: 999rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  flex-shrink: 0;
  width: auto;
}

.gold-btn.mini {
  min-height: 58rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  line-height: 1;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  padding: 26rpx 28rpx 0;
}

.quick-tile {
  min-height: 126rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  overflow: hidden;
}

.quick-tile.warm {
  background: #f9e5e0;
  color: #a82626;
}

.quick-tile.blue {
  background: #e8f0fa;
  color: #375a88;
}

.quick-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.quick-tile view view {
  font-size: 27rpx;
  font-weight: 700;
}

.quick-tile text {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.72;
}

.home-tabs {
  padding: 30rpx 28rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.pill {
  min-height: 66rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e9dfd0;
  color: #5a4f47;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.pill.active {
  background: #c93434;
  border-color: #c93434;
  color: #ffffff;
}

.outline-pill {
  min-height: 84rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 3rpx solid #c93434;
  color: #c93434;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.outline-pill.active {
  background: #c93434;
  color: #ffffff;
}

.with-badge {
  position: relative;
}

.new-badge {
  position: absolute;
  right: -8rpx;
  top: -12rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ed7030;
  color: #ffffff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1.2;
}

.missed-link {
  margin-left: auto;
  flex-shrink: 0;
  color: #5a4f47;
  font-size: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.missed-link.active {
  color: #c93434;
  font-weight: 700;
}

.heart-line {
  color: #c93434;
  font-size: 36rpx;
  line-height: 1;
}

.relation-card,
.push-row,
.profile-card,
.section-card,
.self-card,
.progress-card,
.form-card,
.action-list {
  margin: 0 28rpx 24rpx;
  background: #ffffff;
  border: 2rpx solid #e9dfd0;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(150, 80, 60, 0.05);
}

.relation-card {
  padding: 34rpx 30rpx 38rpx;
}

.relation-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #1f1a17;
}

.relation-sub {
  text-align: center;
  margin-top: 10rpx;
  color: #9a8e84;
  font-size: 24rpx;
}

.relation-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.push-row {
  min-height: 112rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
}

.push-row > view:first-child {
  flex: 1;
}

.push-row view view {
  font-size: 27rpx;
  font-weight: 700;
}

.push-row text {
  color: #9a8e84;
  font-size: 23rpx;
}

.switch {
  width: 82rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #e6ded0;
  padding: 4rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.switch view {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
}

.switch.on {
  background: #c93434;
}

.switch.on view {
  transform: translateX(38rpx);
}

.profile-list {
  padding: 0 0 28rpx;
}

.profile-card {
  padding: 28rpx;
}

.profile-id-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-star {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  background: #f7efe3;
  color: #9a8e84;
  font-size: 22rpx;
  font-weight: 600;
}
.card-star.on {
  background: #f9e5e0;
  color: #c93434;
}
.card-star-text {
  font-size: 22rpx;
}

.profile-id {
  display: inline-flex;
  align-self: flex-start;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  background: #f7efe3;
  color: #b08934;
  font-size: 22rpx;
  font-family: "DIN Alternate", monospace;
  align-items: center;
  justify-content: center;
}

.profile-main,
.detail-head,
.detail-actions,
.self-head,
.follow-card,
.card-head,
.stat-row,
.photo-title,
.sheet-profile,
.bottom-actions {
  display: flex;
  align-items: center;
}

.profile-main {
  margin-top: 22rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 800;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.75);
}

.avatar.big {
  width: 124rpx;
  height: 124rpx;
  font-size: 50rpx;
}

.tone-rose {
  background: #f5d5ce;
  color: #a82626;
}

.tone-sage {
  background: #d8e2d9;
  color: #3a5043;
}

.tone-ocean {
  background: #d6e0ea;
  color: #315879;
}

.tone-indigo {
  background: #dcd9eb;
  color: #464275;
}

.tone-plum {
  background: #ead4e2;
  color: #6b3a52;
}

.tone-gold {
  background: #eadcb8;
  color: #7a5818;
}

.profile-body,
.detail-main,
.self-main,
.notice-copy {
  flex: 1;
  min-width: 0;
}

.profile-body {
  margin-left: 22rpx;
}

.profile-title {
  color: #c93434;
  font-size: 40rpx;
  font-weight: 800;
}

.detail-head {
  margin-left: 22rpx;
  display: flex;
  align-items: center;
}

.info-grid,
.detail-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx 18rpx;
}

.info-grid view,
.detail-grid view {
  min-width: 0;
  display: flex;
  align-items: center;
}

.info-grid text:first-child,
.detail-grid text:first-child,
.pref-row text:first-child {
  color: #9a8e84;
  font-size: 22rpx;
  flex-shrink: 0;
  margin-right: 10rpx;
}

.info-grid text:first-child {
  width: 60rpx;
}

.detail-grid text:first-child {
  width: 100rpx;
}

.pref-row text:first-child {
  width: 140rpx;
}

.info-grid text:last-child,
.detail-grid text:last-child,
.pref-row text:last-child {
  color: #1f1a17;
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-grid .span {
  grid-column: 1 / -1;
}

.desc-box {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
  background: #f7efe3;
  color: #5a4f47;
  font-size: 25rpx;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.desc-box text {
  color: #1f1a17;
  font-weight: 700;
}

.desc-box.full {
  display: block;
  -webkit-line-clamp: unset;
}

.card-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 18rpx;
  width: 100%;
}

.card-actions .btn {
  flex: 1;
  max-width: calc(50% - 9rpx);
}

.btn {
  min-height: 82rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  box-sizing: border-box;
  text-align: center;
  white-space: nowrap;
}

.btn.primary {
  background: #c93434;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(201, 52, 52, 0.24);
}

.btn.outline {
  color: #c93434;
  border: 2rpx solid #c93434;
  background: #ffffff;
}

.btn.muted {
  color: #a82626;
  background: #f9e5e0;
}

.btn.wide {
  flex: 1.35;
}

.side-action,
.float-profile {
  position: fixed;
  right: 0;
  z-index: 40;
  background: linear-gradient(135deg, #f4a23a, #ed7030);
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(237, 112, 48, 0.34);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 1rpx;
  width: 84rpx;
  padding: 14rpx 10rpx;
  border-radius: 999rpx 0 0 999rpx;
  line-height: 1.25;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.side-action {
  bottom: 220rpx;
}

.float-profile {
  top: 320rpx;
}

.detail-card.top {
  margin: -10rpx 0 0;
  border-radius: 26rpx 26rpx 0 0;
  background: #ffffff;
  padding: 32rpx 30rpx;
}

.detail-main {
  margin-left: 22rpx;
}

.mono {
  font-family: "DIN Alternate", Menlo, monospace;
  font-size: 28rpx;
  font-weight: 800;
}

.detail-stats {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  color: #5a4f47;
  font-size: 24rpx;
}

.detail-stats > text {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.detail-stats > text + text {
  margin-left: 24rpx;
}

.detail-stats .ico {
  font-size: 24rpx;
  line-height: 1;
}

.detail-stats .ico.star {
  color: #f4a23a;
}

.detail-stats .ico.flame {
  color: #c93434;
}

.chip-btn {
  min-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f9e5e0;
  color: #c93434;
  font-size: 23rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.detail-actions {
  margin-top: 28rpx;
  gap: 16rpx;
  display: flex;
  align-items: center;
}

.detail-actions .btn {
  flex: 1;
}

.star-action {
  width: 82rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9a8e84;
  font-size: 20rpx;
}

.star-action text:first-child {
  font-size: 32rpx;
  line-height: 1;
}

.star-action.on {
  color: #b08934;
}

.section-card {
  padding: 28rpx;
}

.section-title {
  margin: 28rpx 28rpx 14rpx;
  display: flex;
  align-items: center;
  color: #1f1a17;
  font-size: 31rpx;
  font-weight: 800;
}

.section-title text {
  width: 8rpx;
  height: 32rpx;
  margin-right: 12rpx;
  border-radius: 4rpx;
  background: #c93434;
}

.pref-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.list-card .pref-row {
  padding: 12rpx 28rpx;
}

.pref-row text:first-child {
  margin-right: 16rpx;
}

.pref-row text:last-child {
  flex: 1;
  white-space: normal;
}

.detail-toast {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  /* 在 prev-next (78rpx) + detail-bottom (~130rpx + safe-area) 之上 */
  bottom: calc(240rpx + env(safe-area-inset-bottom));
  z-index: 55;
  background: rgba(38, 24, 20, 0.9);
  color: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  line-height: 1.5;
}

.detail-toast text:first-child {
  flex: 1;
}

.detail-toast text:last-child {
  padding-left: 20rpx;
  font-size: 34rpx;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 18rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 2rpx solid #e9dfd0;
  gap: 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.bottom-actions .btn {
  flex: 1;
}

.detail-bottom {
  bottom: 78rpx;
}

.home-small {
  width: 98rpx;
  color: #5a4f47;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-next {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 51;
  height: 78rpx;
  background: #d8d8d8;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.prev-next button {
  color: #5a4f47;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.follow-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
}

.warn-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f4a23a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.follow-card > text {
  flex: 1;
  margin: 0;
}

.self-card {
  margin-top: -28rpx;
  padding: 30rpx;
  position: relative;
  z-index: 2;
}

.self-main {
  margin-left: 22rpx;
}

.self-id {
  font-size: 30rpx;
  font-weight: 800;
}

.stat-row {
  gap: 34rpx;
  margin-top: 16rpx;
}

.stat-row view view {
  font-size: 34rpx;
  font-weight: 800;
}

.stat-row text {
  color: #9a8e84;
  font-size: 22rpx;
}

.feature-row {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  text-align: center;
  align-items: start;
  position: relative;
}

.feature-row .resource-flag {
  position: absolute;
  left: -16rpx;
  top: -36rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #c93434;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  z-index: 2;
}

.feature-row > view:not(.resource-flag) > text {
  display: block;
}

.feature-row > view:not(.resource-flag) > text:nth-of-type(1) {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f1a17;
}

.feature-row > view:not(.resource-flag) > text:nth-of-type(2) {
  margin-top: 4rpx;
  color: #9a8e84;
  font-size: 21rpx;
}

.round-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  margin: 0 auto;
  background: #f9e5e0;
  color: #c93434;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 800;
  position: relative;
}

.round-icon.dot::after {
  content: "";
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #c93434;
}

.round-icon.ring {
  padding: 8rpx;
  box-sizing: border-box;
}

.round-icon.ring .ring-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #ffffff;
  color: #c93434;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
