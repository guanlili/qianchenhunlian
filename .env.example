# ============================================================
# 乾缘婚恋小程序 · 服务端环境变量
# 拷贝为 .env 后填真实值（.env 已 gitignored）
# 所有 URL 一律使用 IP，禁止 localhost / 127.0.0.1
# ============================================================

# --- 部署机基本信息 ---
# Dev 机外部可达 IP（小程序、admin 都要能访问）
HOST_IP=10.129.209.249

# Domain：备案前留空使用 IP；备案后改为正式域名
DOMAIN=10.129.209.249

# Admin 前端 URL（后端发邮件链接、CORS）
FRONTEND_HOST=http://10.129.209.249:5173

# 环境：local / staging / production
ENVIRONMENT=local

# --- 项目命名 ---
PROJECT_NAME="乾缘婚恋"
STACK_NAME=qianyuan

# --- 后端 ---
# CORS 白名单：admin dev + admin prod 都加
BACKEND_CORS_ORIGINS="http://10.129.209.249:5173,http://10.129.209.249:28080"

# 用 `openssl rand -hex 32` 生成 (此处仅占位, 务必改为自己的随机值)
SECRET_KEY=changethis-run-openssl-rand-hex-32-to-generate

# 首个超级管理员（后台登录用）
FIRST_SUPERUSER=admin@qianyuan.cn
FIRST_SUPERUSER_PASSWORD=changeme123

# --- 微信开放平台（小程序登录用） ---
# AppID/AppSecret 申请下来后填，未填则 /wechat/login 会返回错误
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- 邮件（可选，找回密码用） ---
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@qianyuan.cn
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# --- PostgreSQL ---
# Docker 内服务名（容器互访用 db；宿主机访问用 IP:5432）
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=qianyuan
POSTGRES_USER=qianyuan
POSTGRES_PASSWORD=qianyuan_db_pass_changeme

# --- Sentry（监控，可选）---
SENTRY_DSN=

# --- Docker 镜像名 ---
DOCKER_IMAGE_BACKEND=qianyuan-backend
DOCKER_IMAGE_FRONTEND=qianyuan-admin
