}

.visitor-img {
  width: 100%;
  height: 100%;
}

.visitor-info {
  flex: 1;
  min-width: 0;
}

.visitor-title {
  color: #1f1a17;
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.visitor-time {
  color: #9a8e84;
  font-size: 22rpx;
}

.visitor-arrow {
  color: #c0b0a0;
  font-size: 36rpx;
}

.list-toolbar {
  margin: 18rpx 28rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.list-toolbar-status {
  color: #5a4f47;
  font-size: 26rpx;
  font-weight: 600;
}

.list-toolbar-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.list-toolbar-clear {
  color: #c93434;
  font-size: 24rpx;
  font-weight: 700;
}

.list-toolbar-filter {
  background: #f7efe3;
  color: #c93434;
  border-radius: 24rpx;
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6rpx;
  line-height: 1.6;
}
.list-toolbar-filter::after {
  border: none;
}
.filter-icon {
  font-size: 26rpx;
}

.unlock-tag {
  flex: 1;
  padding: 18rpx 24rpx;
  background: #eaf4ec;
  color: #2d8c4d;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.contact-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #efe4d2;
}

.contact-row:first-of-type {
  margin-top: 12rpx;
}

.contact-label {
  width: 110rpx;
  color: #9a8e84;
  font-size: 24rpx;
}

.contact-value {
  flex: 1;
  font-family: 'PingFang SC', monospace;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f1a17;
  word-break: break-all;
}

.contact-copy-btn {
  flex-shrink: 0;
  background: #c93434;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 22rpx;
  border-radius: 8rpx;
  line-height: 1.6;
}

.contact-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f1a17;
  padding: 8rpx 0;
}

.contact-tip {
  display: block;
  margin-top: 12rpx;
  color: #b0a89e;
  font-size: 22rpx;
  line-height: 1.6;
}
.contact-copy-btn::after {
  border: none;
}

.sheet-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  max-height: 650rpx;
  overflow: auto;
}

.sheet-option {
  min-height: 76rpx;
  padding: 0 16rpx;
  border-radius: 12rpx;
  background: #f7efe3;
  color: #1f1a17;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.sheet-option.selected {
  background: #c93434;
  color: #ffffff;
}
