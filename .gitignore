# ============================================================
# 乾缘婚恋 monorepo · gitignore
# ============================================================

# --- 环境变量 / 密钥 ---
.env
.env.*
!.env.example

# --- 持久化数据 / 日志 (不入 git, 整目录 tar 迁移) ---
data/
logs/

# --- Python (backend/) ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# --- Node / Admin 前端 ---
node_modules/
admin/dist/
admin/.vite/
admin/blob-report/
admin/test-results/
admin/playwright-report/
admin/openapi.json

# --- 微信小程序 ---
miniprogram/miniprogram_npm/
*.sketch.json

# --- IDE / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
