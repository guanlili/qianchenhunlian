.page { min-height: 100vh; background: #fbf6ee; padding: 32rpx 28rpx; }
.header { padding: 16rpx 0 24rpx; }
.title { font-size: 38rpx; font-weight: 800; color: #1f1a17; }
.sub { margin-top: 8rpx; color: #9a8e84; font-size: 24rpx; }
.form-card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 24rpx; }
.content-area { width: 100%; min-height: 280rpx; font-size: 28rpx; color: #1f1a17; }
.counter { text-align: right; color: #9a8e84; font-size: 22rpx; margin-top: 8rpx; }
.label { display: block; color: #9a8e84; font-size: 24rpx; margin-bottom: 12rpx; }
.contact-input { font-size: 28rpx; color: #1f1a17; }
.submit-btn {
  width: 100%; min-height: 96rpx; border-radius: 999rpx;
  background: linear-gradient(90deg, #c93434, #8f1f1f);
  color: #fff; font-size: 32rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-top: 32rpx;
}
