page {
  min-height: 100vh;
  background: #FBF6F1;
  color: #2A2420;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
scroll-view,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 0;
  line-height: 1.2;
  font-size: inherit;
  color: inherit;
  font-family: inherit;
  text-align: center;
  overflow: visible;
}

button:not([size="mini"]) {
  width: auto;
  margin-left: 0;
  margin-right: 0;
}

button::after {
  border: none;
  display: none;
}

input,
textarea {
  font-family: inherit;
}
