page {
  min-height: 100vh;
  background: #FBF6F1;
  color: #2A2420;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
scroll-view,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 0;
  line-height: 1.2;
  font-family: inherit;
}

button::after {
  border: none;
}

input,
textarea {
  font-family: inherit;
}
