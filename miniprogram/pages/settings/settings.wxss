.page { min-height: 100vh; background: #fbf6ee; padding: 32rpx 28rpx; }
.header { padding: 16rpx 0 32rpx; }
.title { font-size: 38rpx; font-weight: 800; color: #1f1a17; }
.section { background: #fff; border-radius: 20rpx; margin-bottom: 24rpx; overflow: hidden; }
.row {
  display: flex; align-items: center; padding: 28rpx 28rpx;
  border-bottom: 2rpx solid #f4ece0;
}
.row:last-child { border-bottom: 0; }
.row-main { flex: 1; }
.row-label { font-size: 30rpx; color: #1f1a17; font-weight: 600; }
.row-sub { margin-top: 6rpx; color: #9a8e84; font-size: 22rpx; }
.row-arrow { color: #c0b6a8; font-size: 36rpx; }
